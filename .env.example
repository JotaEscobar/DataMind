# ------------------------------------------------------------------------------
# DATAMIND 2.0 - ARCHIVO DE CONFIGURACIÓN CONSOLIDADO
# ------------------------------------------------------------------------------

# --- BACKEND (Python / FastAPI) ---
# Groq API Key - obtenla en https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Selección de modelos
FAST_MODEL=groq/llama-3.1-8b-instant    # Para clasificar intención y títulos
MAIN_MODEL=groq/llama3-70b-8192          # Para análisis principal

# --- DOCKER / INFRA ---
# Host de Ollama (ajusta si usas Localhost o Docker)
OLLAMA_HOST=http://host.docker.internal:11434

# --- FRONTEND (React / Vite) ---
# URL de la API (debe empezar con VITE_ para que Vite la reconozca)
VITE_API_URL=http://localhost:8000
